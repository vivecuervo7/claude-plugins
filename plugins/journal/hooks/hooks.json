{
  "description": "Journal plugin hooks — recap nudge on session start",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/journal/scripts/journal-recap-check.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
